# NeuroChiro Production Environment Variables
# Copy this to .env.local and fill in real values

# === REQUIRED ===

# Supabase (Database & Auth)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Stripe (Payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_GROWTH_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."

# Anthropic (AI Bio Generator + Contract Lab)
ANTHROPIC_API_KEY="sk-ant-..."

# Resend (Emails)
RESEND_API_KEY="re_..."

# Site URL
NEXT_PUBLIC_SITE_URL="https://neurochiro.co"

# Founder Access (comma-separated emails)
NEXT_PUBLIC_FOUNDER_EMAILS="drray@neurochirodirectory.com,raymond@neurochiro.com"

# Cron Job Security (generate with: openssl rand -hex 32)
CRON_SECRET="your-random-secret-here"

# === REQUIRED FOR FEATURES ===

# Mapbox (Directory Map)
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1..."

# Discord (Admin Alerts)
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."

# === OPTIONAL ===

# Twilio (SMS notifications — app works without these)
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_PHONE="+1..."

# Google Places (Doctor profile reviews — shows empty state without this)
# GOOGLE_PLACES_API_KEY="AIza..."
